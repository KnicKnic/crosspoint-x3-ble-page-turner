<Window x:Class="X3LaptopCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:X3LaptopCompanion"
        mc:Ignorable="d"
        Title="X3 Laptop Companion"
        Height="720"
        Width="620"
        MinHeight="700"
        MinWidth="560"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="X3 Laptop Companion"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock Text="Teams mute control over BLE"
                       Margin="0,4,0,0"
                       Foreground="#555555" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,20"
                Padding="16"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="X3 connection" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding ConnectionText}" />

                <TextBlock Grid.Row="1" Text="Teams" Margin="0,8,0,0" FontWeight="SemiBold" />
                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding TeamsText}" />

                <TextBlock Grid.Row="2" Text="Microphone" Margin="0,8,0,0" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Text="{Binding MicrophoneText}" />

                <TextBlock Grid.Row="3" Text="Camera" Margin="0,8,0,0" FontWeight="SemiBold" />
                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Text="{Binding CameraText}" />

                <TextBlock Grid.Row="4" Text="Meeting" Margin="0,8,0,0" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Text="{Binding MeetingText}" />

                <TextBlock Grid.Row="5" Text="Hand" Margin="0,8,0,0" FontWeight="SemiBold" />
                <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" Text="{Binding HandText}" />

                <TextBlock Grid.Row="6" Text="Test mode" Margin="0,8,0,0" FontWeight="SemiBold" />
                <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,8,0,0" Text="{Binding TestModeText}" />

                <TextBlock Grid.Row="7" Text="Teams mode" Margin="0,8,0,0" FontWeight="SemiBold" />
                <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,8,0,0" Text="{Binding TeamsModeText}" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2">
            <CheckBox Content="Test mode"
                      IsChecked="{Binding IsTestMode, Mode=TwoWay}"
                      Margin="0,0,0,8" />
            <CheckBox Content="Teams dry run"
                      IsChecked="{Binding IsTeamsDryRun, Mode=TwoWay}"
                      Margin="0,0,0,10" />
            <GroupBox Header="Teams commands"
                      Margin="0,0,0,10">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Target PID"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <TextBox Grid.Column="1"
                             Text="{Binding CommandTargetProcessIdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" />

                    <UniformGrid Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Rows="1"
                                 Columns="4">
                        <Button Content="Mute"
                                Margin="0,0,8,0"
                                Click="ToggleMute_Click" />
                        <Button Content="Speaker"
                                Margin="0,0,8,0"
                                Click="ToggleSpeaker_Click" />
                        <Button Content="Hand"
                                Margin="0,0,8,0"
                                Click="ToggleHand_Click" />
                        <Button Content="Video"
                                Click="ToggleVideo_Click" />
                    </UniformGrid>
                </Grid>
            </GroupBox>
            <GroupBox Header="UIA window dump"
                      Margin="0,0,0,10">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Window"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding WindowDumpTargetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0" />
                    <Button Grid.Column="2"
                            Content="Dump"
                            Margin="0,0,8,0"
                            Click="DumpWindow_Click" />
                    <Button Grid.Column="3"
                            Content="List"
                            Click="ListWindows_Click" />
                </Grid>
            </GroupBox>
            <GroupBox Header="Test status"
                      Margin="0,0,0,10">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <CheckBox Content="{Binding TestTeamsToggleText}"
                              IsChecked="{Binding TestTeamsDetected, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,8" />
                    <CheckBox Grid.Column="1"
                              Content="{Binding TestMeetingToggleText}"
                              IsChecked="{Binding TestMeetingDetected, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,8" />
                    <Button Grid.Column="2"
                            Content="{Binding TestMicrophoneToggleText}"
                            Margin="0,0,8,8"
                            Click="CycleTestMicrophone_Click" />
                    <Button Grid.Column="3"
                            Content="{Binding TestCameraToggleText}"
                            Margin="0,0,8,8"
                            Click="CycleTestCamera_Click" />
                    <Button Grid.Column="4"
                            Content="{Binding TestHandToggleText}"
                            Margin="0,0,8,8"
                            Click="CycleTestHand_Click" />
                    <TextBox Grid.Column="5"
                             Text="{Binding TestMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1"
                               Text="Meeting name"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Grid.ColumnSpan="5"
                             Text="{Binding TestMeetingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2"
                               Grid.ColumnSpan="6"
                               Text="Enable test mode to send these simulated values over BLE."
                               Foreground="#555555" />
                </Grid>
            </GroupBox>
            <TextBlock Text="{Binding DetailText}"
                       TextWrapping="Wrap"
                       Foreground="#333333" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Simulate X3 Press"
                    Width="130"
                    Margin="0,0,8,0"
                    Click="SimulateX3Mute_Click" />
            <Button Content="Test Status"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="SendTestStatus_Click" />
            <Button Content="Open Log"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="OpenLog_Click" />
            <Button Content="Toggle Mute"
                    Width="110"
                    Margin="0,0,8,0"
                    Click="ToggleMute_Click" />
            <Button Content="Hide"
                    Width="80"
                    Click="Hide_Click" />
        </StackPanel>
    </Grid>
</Window>
